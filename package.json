{
  "name": "git-buddy",
  "private": false,
  "version": "0.0.0",
  "description": "Interactive Git CLI toolkit: Branch Sweeper, GitHub Issue to Branch, and Safe Git Undo.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "bin": {
    "bsweep": "./dist/branch-sweep-terminate.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "dev": "ts-node --esm src/index.ts",
    "start": "pnpm check && pnpm build && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint-staged": "lint-staged",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check .",
    "check@fix": "biome check . --write",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\""
  },
  "keywords": [
    "cli",
    "scaffold",
    "typescript",
    "generator"
  ],
  "author": "zibasan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zibasan/git-buddy.git"
  },
  "bugs": {
    "url": "https://github.com/zibasan/git-buddy/issues"
  },
  "homepage": "https://github.com/zibasan/git-buddy#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "inquirer": "^13.3.2",
    "log-symbols": "^7.0.1",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.5.0",
    "commit-wand": "^1.0.22",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md}": [
      "biome check --write"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}